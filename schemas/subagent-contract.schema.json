{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/codex-task-contract-skill/schemas/subagent-contract.schema.json",
  "title": "Subagent Contract Draft Schema",
  "description": "Draft structural schema for defining subagent delegation contracts under task-contract Skill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "parent_conversation_id",
    "subagent_role",
    "scope_boundary",
    "allowed_paths",
    "forbidden_paths",
    "allowed_tools",
    "forbidden_tools",
    "acceptance_criteria",
    "constraints",
    "recursion_lock",
    "approval_gate",
    "evidence_required",
    "return_format",
    "merge_policy",
    "failure_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "0.5.0-draft"
    },
    "parent_conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "subagent_role": {
      "type": "string",
      "minLength": 1
    },
    "scope_boundary": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "allowed_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_tools": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "handoff_input": {
      "type": "object"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "max_iterations": {
      "type": "integer",
      "minimum": 1
    },
    "recursion_lock": {
      "type": "boolean"
    },
    "approval_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "type": "string" },
        "blocked_action": { "type": "string" },
        "recommended_safe_default": { "type": "string" },
        "reply_template": { "type": "string" }
      }
    },
    "evidence_required": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "return_format": {
      "type": "string",
      "minLength": 1
    },
    "return_schema": {
      "type": "object"
    },
    "merge_policy": {
      "type": "string",
      "enum": [
        "parent_only",
        "parent_review_required",
        "no_merge_allowed"
      ]
    },
    "failure_policy": {
      "type": "string",
      "enum": [
        "escalate_to_parent",
        "stop_without_retry",
        "retry_with_parent_approval"
      ]
    }
  }
}
